    family-names: Shrestha
    orcid: "https://orcid.org/0009-0004-8330-4348"
    affiliation: "University of Miami"
repository-code: "https://github.com/OfficialBishal/PertEMA"
url: "https://shresthabishal.com/projects/pertema/"
license: MIT
version: "0.1.0"
date-released: "2026-07-22"
keywords:
  - single-cell
  - perturbation prediction
  - Perturb-seq
  - reliability estimation
  - conformal prediction
  - selective prediction
  - uncertainty quantification
